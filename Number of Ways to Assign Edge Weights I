class Solution {
public:
    typedef long long ll;   
    
    int M = 1e9 + 7;

    ll power(ll base, ll exponent) {
        if(exponent == 0) {
            return 1;
        }

        ll half = power(base, exponent / 2);

        ll result = (half * half) % M;

        if(exponent & 1) {
            result = (result * base) % M;
        }

        return result;
    }

    int getMaxDepth(int node, int parent, unordered_map<int, vector<int>>& adj) {
        int depth = 0;

        for(int& ngbr : adj[node]) {
            if(ngbr == parent) continue;

            depth = max(depth, getMaxDepth(ngbr, node, adj) + 1);
        }

        return depth;
    }

    int assignEdgeWeights(vector<vector<int>>& edges) {
        // Build Adjacency list
        unordered_map<int, vector<int>> adj;

        for(auto& edge : edges) {
            int u = edge[0];
            int v = edge[1];

            adj[u].push_back(v);
            adj[v].push_back(u);
        }

        int d = getMaxDepth(1, -1, adj);

        return power(2, d- 1);
    }
};
