class Solution {
public:
    int minimumCost(vector<int>& cost) {
        sort(cost.rbegin(), cost.rend());

        int minCost = 0;
        int n = cost.size();

        for(int i = 0; i < n; i++) {
            if((i + 1) % 3 == 0) // skip indices (2, 5, 8...)
                continue;
            minCost += cost[i];
        }

        return minCost;
    }
};
