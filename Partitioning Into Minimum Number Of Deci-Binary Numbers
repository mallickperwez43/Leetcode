// Brute Force

class Solution {
public:
    int minPartitions(string n) {
        int count = 0;

        while(true) {
            bool changed = false;

            for(char& ch : n) {
                if(ch != '0') {
                    ch--; // subtract 1
                    changed = true;
                }
            }

            if(!changed)
                break;
            
            count++;
        }

        return count;
    }
};


// Optimal

class Solution {
public:
    int minPartitions(string n) {
        char maxChar = *max_element(n.begin(), n.end());

        return maxChar - '0';
    }
};
