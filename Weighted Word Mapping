class Solution {
public:
    string mapWordWeights(vector<string>& words, vector<int>& weights) {
        string result = "";

        for(string& word : words) {
            int curr = 0;
            for(char& ch : word) {
                curr += weights[ch - 'a'];
            }
            result += ('z' - curr % 26);
        }

        return result;
    }
};
