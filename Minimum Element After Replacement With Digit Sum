class Solution {
public:
    int getSum(int num) {
        int temp = num;
        int res = 0;

        while(temp) {
            res += (temp % 10);
            temp /= 10;
        }

        return res;
    }

    int minElement(vector<int>& nums) {
        int result = INT_MAX;
        
        for(int& num : nums) {
            int currSum = getSum(num);
            result = min(result, currSum);
        }

        return result;
    }
};
